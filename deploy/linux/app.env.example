APP_NAME=客户现场交付档案中心
LISTEN_ADDR=:8080
BASE_URL=http://127.0.0.1:8080
TOKEN_SECRET=please-change-this-secret
ACCESS_TOKEN_TTL=2h
REFRESH_TOKEN_TTL=168h

STORAGE_BACKEND=mysql
# 注意：DSN 请保留双引号，避免 bash source 时把括号或 & 当作特殊字符解析
MYSQL_DSN="app_user:app_password@tcp(127.0.0.1:3306)/customer_delivery_log?charset=utf8mb4&parseTime=true&loc=Local"

UPLOAD_DIR=./uploads
WEB_DIR=./web

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=PleaseChangeMe123!
SEED_ADMIN_REAL_NAME=系统管理员
MAX_UPLOAD_SIZE_BYTES=52428800
